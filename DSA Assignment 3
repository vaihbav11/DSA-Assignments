class Solution:
    def minimumAddedCoins(self, coins, target):
        coins.sort()
        reach = 0
        added = 0
        i = 0

        while reach < target:
            if i < len(coins) and coins[i] <= reach + 1: 
                # this coin extends our reach
                reach += coins[i]
                i += 1
            else:
                # gap found — add the missing coin
                reach += reach + 1  # add coin of value (reach+1)
                added += 1

        return added
